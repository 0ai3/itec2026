{
  "name": "itec2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "collab:server": "node ./server/yjs-websocket-server.mjs",
    "dev:collab": "concurrently -n web,collab -c auto \"npm:dev\" \"npm:collab:server\"",
    "dev:collab:lan": "concurrently -n web,collab -c auto \"npm:dev:lan\" \"npm:collab:server\"",
    "dev:collab:lan:autoip": "sh ./scripts/dev-collab-lan-autoip.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "docker": "^0.2.14",
    "dockerode": "^4.0.10",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^4.0.0",
    "firebase": "^12.11.0",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.53.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tar-stream": "^3.1.8",
    "ws": "^8.20.0",
    "y-monaco": "^0.1.6",
    "y-websocket": "^3.0.0",
    "y-websocket-legacy": "npm:y-websocket@^1.5.4",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/tar-stream": "^3.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "type": "module"
}
